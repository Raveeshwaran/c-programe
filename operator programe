#include <stdio.h>
#include <math.h>

int main() {
    // 1. Print Hello World
    printf("Hello World!\n");

    // 2. Add, Subtract, Multiply, Divide, Modulus
    int a = 10, b = 3;
    printf("Addition: %d\n", a + b);
    printf("Subtraction: %d\n", a - b);
    printf("Multiplication: %d\n", a * b);
    printf("Division: %d\n", a / b);
    printf("Modulus: %d\n", a % b);

    // 3. Square Root
    int num = 25;
    printf("Square Root: %.2f\n", sqrt(num));

    // 4. Area of Triangle
    float base = 10, height = 5;
    float area = 0.5 * base * height;
    printf("Area of Triangle: %.2f\n", area);

    // 5. Quadratic Equation Formulas
    int x = 4, y = 2;
    printf("(a+b)^2 = %d\n", (x + y) * (x + y));
    printf("(a-b)^2 = %d\n", (x - y) * (x - y));
    printf("a^2 - b^2 = %d\n", (x * x - y * y));

    // 6. Swap Two Variables
    int p = 5, q = 10, temp;
    // Using third variable
    temp = p;
    p = q;
    q = temp;
    printf("Swap using third variable: %d %d\n", p, q);

    // Without third variable
    p = 5; q = 10;
    p = p + q;
    q = p - q;
    p = p - q;
    printf("Swap without third variable: %d %d\n", p, q);

    // 7. Kilometers to Miles
    float km = 10;
    float miles = km * 0.63;
    printf("Miles: %.2f\n", miles);

    // 8. Celsius to Fahrenheit
    float celsius = 37;
    float fahrenheit = (celsius * 1.8) + 32;
    printf("Fahrenheit: %.2f\n", fahrenheit);

    // 9. Last digit of number
    int n = 1234;
    printf("Last digit: %d\n", n % 10);

    // 10. Last two digits of number
    printf("Last two digits: %d\n", n % 100);

    // 11. Square middle digit of 5-digit number
    int five = 54623;
    int middle_digit = (five / 100) % 10;
    printf("Square of %d is: %d\n", middle_digit, middle_digit * middle_digit);

    return 0;
}

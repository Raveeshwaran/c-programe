// 37. Find the product of array except self
void productExceptSelf(int arr[], int n, int result[]) {
    int *leftProduct = (int *)malloc(n * sizeof(int));
    int *rightProduct = (int *)malloc(n * sizeof(int));

    leftProduct[0] = 1;
    for (int i = 1; i < n; i++) {
        leftProduct[i] = leftProduct[i - 1] * arr[i - 1];
    }

    rightProduct[n - 1] = 1;
    for (int i = n - 2; i >= 0; i--) {
        rightProduct[i] = rightProduct[i + 1] * arr[i + 1];
    }

    for (int i = 0; i < n; i++) {
        result[i] = leftProduct[i] * rightProduct[i];
    }

    free(leftProduct);
    free(rightProduct);
}


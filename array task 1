// 33. Rearrange positive and negative alternatively
void rearrangePosNeg(int arr[], int n) {
    int *temp = (int *)malloc(n * sizeof(int));
    int posIdx = 0, negIdx = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] >= 0) {
            temp[posIdx] = arr[i];
            posIdx += 2;
        } else {
            if (negIdx == 0) negIdx = 1;
            temp[negIdx] = arr[i];
            negIdx += 2;
        }
    }
    for (int i = 0; i < n; i++) arr[i] = temp[i];
    free(temp);
}


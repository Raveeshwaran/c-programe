// 49. Print matrix in spiral order
void printSpiralOrder(int mat[][3], int rows, int cols) {
    int top = 0, bottom = rows - 1, left = 0, right = cols - 1;
    printf("Spiral Order: ");
    while (top <= bottom && left <= right) {
        for (int i = left; i <= right; i++) {
            printf("%d ", mat[top][i]);
        }
        top++;

        for (int i = top; i <= bottom; i++) {
            printf("%d ", mat[i][right]);
        }
        right--;

        if (top <= bottom) {
            for (int i = right; i >= left; i--) {
                printf("%d ", mat[bottom][i]);
            }
            bottom--;
        }

        if (left <= right) {
            for (int i = bottom; i >= top; i--) {
                printf("%d ", mat[i][left]);
            }
            left++;
        }
    }
    printf("\n");
}

// 50. Rotate matrix by 90 
void rotateMatrix90(int mat[][3], int n) {
    // First transpose
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            int temp = mat[i][j];
            mat[i][j] = mat[j][i];
            mat[j][i] = temp;
        }
    }

    // Then reverse each row
    for (int i = 0; i < n; i++) {
        int start = 0, end = n - 1;
        while (start < end) {
            int temp = mat[i][start];
            mat[i][start] = mat[i][end];
            mat[i][end] = temp;
            start++;
            end--;
        }
    }
}



// 51. Find string length without strlen()
int stringLength(char str[]) {
    int len = 0;
    while (str[len] != '\0') {
        len++;
    }
    return len;
}

// 52. Reverse a string
void reverseString(char str[]) {
    int n = stringLength(str);
    for (int i = 0; i < n / 2; i++) {
        char temp = str[i];
        str[i] = str[n - 1 - i];
        str[n - 1 - i] = temp;
    }
}

// 53. Check palindrome
int isPalindrome(char str[]) {
    int n = stringLength(str);
    for (int i = 0; i < n / 2; i++) {
        if (str[i] != str[n - 1 - i]) return 0;
    }
    return 1;
}

// 54. Count vowels, consonants, digits, and special characters
void countCharacters(char str[], int *vowels, int *consonants, int *digits, int *special) {
    *vowels = *consonants = *digits = *special = 0;
    for (int i = 0; str[i] != '\0'; i++) {
        if ((str[i] >= 'a' && str[i] <= 'z') || (str[i] >= 'A' && str[i] <= 'Z')) {
            if (str[i] == 'a' || str[i] == 'e' || str[i] == 'i' || str[i] == 'o' || str[i] == 'u' ||
                str[i] == 'A' || str[i] == 'E' || str[i] == 'I' || str[i] == 'O' || str[i] == 'U') {
                (*vowels)++;
            } else {
                (*consonants)++;
            }
        } else if (str[i] >= '0' && str[i] <= '9') {
            (*digits)++;
        } else if (str[i] != ' ') {
            (*special)++;
        }
    }
}


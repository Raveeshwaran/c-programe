// 61. Two Sum problem
void twoSum(int arr[], int n, int target) {
    printf("Pairs with sum %d: ", target);
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] + arr[j] == target) {
                printf("(%d, %d) ", arr[i], arr[j]);
            }
        }
    }
    printf("\n");
}

// 62. Trapping Rain Water
int trapRainWater(int arr[], int n) {
    int *left = (int *)malloc(n * sizeof(int));
    int *right = (int *)malloc(n * sizeof(int));

    left[0] = arr[0];
    for (int i = 1; i < n; i++) {
        left[i] = (left[i - 1] > arr[i]) ? left[i - 1] : arr[i];
    }

    right[n - 1] = arr[n - 1];
    for (int i = n - 2; i >= 0; i--) {
        right[i] = (right[i + 1] > arr[i]) ? right[i + 1] : arr[i];
    }

    int water = 0;
    for (int i = 0; i < n; i++) {
        int minHeight = (left[i] < right[i]) ? left[i] : right[i];
        water += minHeight - arr[i];
    }

    free(left);
    free(right);
    return water;
}

// 63. Maximum Product Subarray
int maxProductSubarray(int arr[], int n) {
    int maxProd = arr[0], minProd = arr[0], result = arr[0];
    for (int i = 1; i < n; i++) {
        int tempMax = maxProd;
        maxProd = (arr[i] > (maxProd * arr[i])) ? arr[i] : (maxProd * arr[i]);
        maxProd = (maxProd > (minProd * arr[i])) ? maxProd : (minProd * arr[i]);

        minProd = (arr[i] < (tempMax * arr[i])) ? arr[i] : (tempMax * arr[i]);
        minProd = (minProd < (minProd * arr[i])) ? minProd : (minProd * arr[i]);

        result = (result > maxProd) ? result : maxProd;
    }
    return result;
}

// 64. Stock Buy and Sell (Maximum Profit)
int maxProfit(int arr[], int n) {
    if (n < 2) return 0;
    int minPrice = arr[0], maxProfit = 0;
    for (int i = 1; i < n; i++) {
        if (arr[i] - minPrice > maxProfit) {
            maxProfit = arr[i] - minPrice;
        }
        if (arr[i] < minPrice) {
            minPrice = arr[i];
        }
    }
    return maxProfit;
}

// 65. Container With Most Water
int containerWithMostWater(int arr[], int n) {
    int left = 0, right = n - 1, maxArea = 0;
    while (left < right) {
        int height = (arr[left] < arr[right]) ? arr[left] : arr[right];
        int area = height * (right - left);
        maxArea = (area > maxArea) ? area : maxArea;

        if (arr[left] < arr[right]) left++;
        else right--;
    }
    return maxArea;
}

// 66. Merge Intervals
void mergeIntervals(int intervals[][2], int n) {
    // Sort intervals by start point
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (intervals[j][0] > intervals[j + 1][0]) {
                int temp0 = intervals[j][0], temp1 = intervals[j][1];
                intervals[j][0] = intervals[j + 1][0];
                intervals[j][1] = intervals[j + 1][1];
                intervals[j + 1][0] = temp0;
                intervals[j + 1][1] = temp1;
            }
        }
    }

    printf("Merged intervals: ");
    int start = intervals[0][0], end = intervals[0][1];
    for (int i = 1; i < n; i++) {
        if (intervals[i][0] <= end) {
            end = (intervals[i][1] > end) ? intervals[i][1] : end;
        } else {
            printf("[%d, %d] ", start, end);
            start = intervals[i][0];
            end = intervals[i][1];
        }
    }
    printf("[%d, %d]\n", start, end);
}

// 67. Find Peak Element
int findPeak(int arr[], int n) {
    if (n == 1) return 0;
    for (int i = 0; i < n; i++) {
        if ((i == 0 || arr[i] > arr[i - 1]) && (i == n - 1 || arr[i] > arr[i + 1])) {
            return i;
        }
    }
    return -1;
}

// 68. Dutch National Flag (Sort 0s, 1s, and 2s)
void dutchNationalFlag(int arr[], int n) {
    int low = 0, mid = 0, high = n - 1;
    while (mid <= high) {
        if (arr[mid] == 0) {
            int temp = arr[low];
            arr[low] = arr[mid];
            arr[mid] = temp;
            low++;
            mid++;
        } else if (arr[mid] == 1) {
            mid++;
        } else {
            int temp = arr[mid];
            arr[mid] = arr[high];
            arr[high] = temp;
            high--;
        }
    }
}


// 1. Find the largest element
int findLargest(int arr[], int n) {
    int max = arr[0];
    for (int i = 1; i < n; i++) {
        if (arr[i] > max) max = arr[i];
    }
    return max;
}

// 2. Find the smallest element
int findSmallest(int arr[], int n) {
    int min = arr[0];
    for (int i = 1; i < n; i++) {
        if (arr[i] < min) min = arr[i];
    }
    return min;
}

// 3. Calculate the sum of all elements
int calculateSum(int arr[], int n) {
    int sum = 0;
    for (int i = 0; i < n; i++) {
        sum += arr[i];
    }
    return sum;
}

// 4. Calculate the average
float calculateAverage(int arr[], int n) {
    return (float)calculateSum(arr, n) / n;
}

// 5. Count even and odd numbers
void countEvenOdd(int arr[], int n, int *even, int *odd) {
    *even = *odd = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] % 2 == 0) (*even)++;
        else (*odd)++;
    }
}

// 6. Linear search
int linearSearch(int arr[], int n, int target) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == target) return i;
    }
    return -1;
}

// 7. Reverse an array
void reverseArray(int arr[], int n) {
    int start = 0, end = n - 1;
    while (start < end) {
        int temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;
        start++;
        end--;
    }
}

// 8. Copy one array to another
void copyArray(int src[], int dest[], int n) {
    for (int i = 0; i < n; i++) {
        dest[i] = src[i];
    }
}

// 9. Print array elements in reverse order
void printReverse(int arr[], int n) {

// 17. Left rotate by one position
void leftRotateOne(int arr[], int n) {
    int temp = arr[0];
    for (int i = 0; i < n - 1; i++) {
        arr[i] = arr[i + 1];
    }
    arr[n - 1] = temp;
}

// 18. Right rotate by one position
void rightRotateOne(int arr[], int n) {
    int temp = arr[n - 1];
    for (int i = n - 1; i > 0; i--) {
        arr[i] = arr[i - 1];
    }
    arr[0] = temp;
}

// 19. Rotate array by K positions
void rotateByK(int arr[], int n, int k) {
    k = k % n;
    reverseArray(arr, k);
    reverseArray(arr + k, n - k);
    reverseArray(arr, n);
}


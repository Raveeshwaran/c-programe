    for (int i = 0; i < n; i++) {
        int greater = -1;
        for (int j = i + 1; j < n; j++) {
            if (arr[j] > arr[i]) {
                greater = arr[j];
                break;
            }
        }
        printf("%d ", greater);
    }
    printf("\n");
}

// 70. Circular Array Rotation
void circularRotation(int arr[], int n, int k) {
    k = k % n;
    reverseArray(arr, n - k);
    reverseArray(arr + n - k, k);
    reverseArray(arr, n);
}

// 71. Rotate array without using another array
void rotateWithoutExtraSpace(int arr[], int n, int k) {
    k = k % n;
    reverseArray(arr, k);
    reverseArray(arr + k, n - k);
    reverseArray(arr, n);
}

// 72. Reverse array using pointers
void reverseUsingPointers(int *arr, int n) {
    int *start = arr;
    int *end = arr + n - 1;
    while (start < end) {
        int temp = *start;
        *start = *end;
        *end = temp;
        start++;
        end--;
    }
}

// 73. Remove an element without creating a new array
int removeElement(int arr[], int n, int target) {
    int index = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] != target) {
            arr[index++] = arr[i];
        }
    }
    return index;
}

// 74. Insert an element at a specific position
void insertElement(int arr[], int n, int pos, int element, int *newSize) {
    for (int i = n; i > pos; i--) {
        arr[i] = arr[i - 1];
    }
    arr[pos] = element;
    *newSize = n + 1;
}

// 75. Delete an element from a specific position
void deleteElement(int arr[], int n, int pos, int *newSize) {
    for (int i = pos; i < n - 1; i++) {
        arr[i] = arr[i + 1];
    }
    *newSize = n - 1;
}

// 76. Find all unique elements
void findUnique(int arr[], int n) {
    printf("Unique elements: ");
    for (int i = 0; i < n; i++) {
        int isUnique = 1;
        for (int j = 0; j < n; j++) {
            if (i != j && arr[i] == arr[j]) {
                isUnique = 0;
                break;
            }
        }
        if (isUnique) printf("%d ", arr[i]);
    }
    printf("\n");
}

// 77. Check if two arrays are identical
int areIdentical(int arr1[], int arr2[], int n) {
    for (int i = 0; i < n; i++) {
        if (arr1[i] != arr2[i]) return 0;
    }
    return 1;
}

// 78. Find the first repeating element
int firstRepeating(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) return arr[i];
        }
    }
    return -1;
}

// 79. Find the first non-repeating element
int firstNonRepeating(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        int found = 0;
        for (int j = 0; j < n; j++) {
            if (i != j && arr[i] == arr[j]) {
                found = 1;
                break;
            }
        }
        if (!found) return arr[i];
    }
    return -1;
}

// 80. Rearrange even indices have even numbers and odd indices have odd numbers
void rearrangeEvenOdd(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        if (i % 2 == 0) {
            // Even index should have even number
            if (arr[i] % 2 != 0) {
                for (int j = i + 1; j < n; j++) {
                    if (arr[j] % 2 == 0) {
                        int temp = arr[i];
                        arr[i] = arr[j];
                        arr[j] = temp;
                        break;
                    }
                }
            }
        } else {
            // Odd index should have odd number
            if (arr[i] % 2 == 0) {
                for (int j = i + 1; j < n; j++) {
                    if (arr[j] % 2 != 0) {
                        int temp = arr[i];
                        arr[i] = arr[j];
                        arr[j] = temp;
                        break;
                    }
                }
            }
        }
    }
}


}

// 39. Find the median of two sorted arrays
float medianSortedArrays(int arr1[], int n1, int arr2[], int n2) {
    int *merged = (int *)malloc((n1 + n2) * sizeof(int));
    mergeArrays(arr1, n1, arr2, n2, merged);
    int totalLen = n1 + n2;
    float median = (totalLen % 2 == 0) ?
        (float)(merged[totalLen / 2 - 1] + merged[totalLen / 2]) / 2 :
        (float)merged[totalLen / 2];
    free(merged);
    return median;
}

// 40. Find the longest increasing subsequence
int longestIncreasingSubsequence(int arr[], int n) {
    int *dp = (int *)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) dp[i] = 1;

    for (int i = 1; i < n; i++) {
        for (int j = 0; j < i; j++) {
            if (arr[j] < arr[i]) {
                dp[i] = (dp[i] > dp[j] + 1) ? dp[i] : dp[j] + 1;
            }
        }
    }

    int maxLen = dp[0];
    for (int i = 1; i < n; i++) {
        maxLen = (maxLen > dp[i]) ? maxLen : dp[i];
    }
    free(dp);
    return maxLen;
}



// 41. Matrix addition
void matrixAddition(int mat1[][3], int mat2[][3], int result[][3], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            result[i][j] = mat1[i][j] + mat2[i][j];
        }
    }
}

// 42. Matrix subtraction
void matrixSubtraction(int mat1[][3], int mat2[][3], int result[][3], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            result[i][j] = mat1[i][j] - mat2[i][j];
        }
    }
}

// 43. Matrix multiplication
void matrixMultiplication(int mat1[][3], int mat2[][3], int result[][3], int r1, int c1, int r2, int c2) {
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            result[i][j] = 0;
            for (int k = 0; k < c1; k++) {
                result[i][j] += mat1[i][k] * mat2[k][j];
            }
        }
    }
}

// 44. Matrix transpose
void matrixTranspose(int mat[][3], int result[][3], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            result[j][i] = mat[i][j];
        }
    }
}

// 45. Check if matrix is symmetric
int isSymmetric(int mat[][3], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (mat[i][j] != mat[j][i]) return 0;
        }
    }
    return 1;
}

// 46. Find row-wise and column-wise sums
void rowColumnSums(int mat[][3], int rows, int cols, int rowSum[], int colSum[]) {
    for (int i = 0; i < rows; i++) {
        rowSum[i] = 0;
        for (int j = 0; j < cols; j++) {
            rowSum[i] += mat[i][j];
        }
    }
    for (int j = 0; j < cols; j++) {
        colSum[j] = 0;
        for (int i = 0; i < rows; i++) {
            colSum[j] += mat[i][j];
        }
    }
}

// 47. Find diagonal sums
void diagonalSums(int mat[][3], int n, int *principal, int *secondary) {
    *principal = *secondary = 0;
    for (int i = 0; i < n; i++) {
        *principal += mat[i][i];
        *secondary += mat[i][n - 1 - i];
    }
}

